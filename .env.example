# Hive Mind — Secrets
# Copy to .env and fill in real values.

OPENAI_API_KEY=sk-proj-your-key-here

GOOGLE_MAP_API_KEY=your-google-maps-key
GOOGLE_CAL_API_KEY=your-google-calendar-key

X_BEARER_TOKEN=your-x-bearer-token

VIRUSTOTAL_API=your-virustotal-api-key
IPTHREAT_API=your-ipthreat-api-key

GITEA_TOKEN=your-gitea-token
GITEA__database__PASSWD=your-gitea-db-password

SPARKDB_USER=your-db-user
SPARKDB_PASSWORD=your-db-password
DB_HOST=your-db-host.postgres.database.azure.com
DB_NAME=your-db-name
DB_PORT=5432

DEV_DB_USER=postgres
DEV_DB_PASSWORD=your-dev-db-password
DEV_DB_HOST=localhost
DEV_DB_NAME=network
DEV_DB_PORT=5432

DISCORD_BOT_TOKEN=your-discord-bot-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_OWNER_CHAT_ID=your-telegram-chat-id

# SMTP — for fallback email notifications when Telegram is unavailable
# Gmail: use an App Password (myaccount.google.com/apppasswords), not your account password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TO=your-email@gmail.com
